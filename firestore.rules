rules_version = '2';

// قواعد أمان Firestore لمشروع مقام — استخدام شخصي بمالك واحد فقط.
// المبدأ: لا وصول لأي بيانات إلا من حساب المالك المصادَق عليه.
// استُبدل project id الفعلي تلقائيًا عند الربط؛ لا حاجة لتعديل هذا الملف يدويًا.

service cloud.firestore {
  match /databases/{database}/documents {

    // كل التجميعات (bars وما يُضاف لاحقًا) محمية بنفس القاعدة:
    // القراءة والكتابة لصاحب الحساب فقط بعد تسجيل الدخول.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
